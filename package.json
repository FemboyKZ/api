{
  "name": "server-api",
  "version": "1.0.0",
  "description": "Game server tracking API with real-time updates",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "npx eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "npx eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "admin:aggregate": "curl -X POST http://localhost:3000/admin/aggregate-daily",
    "admin:cleanup": "curl -X POST http://localhost:3000/admin/cleanup-history?days=30"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "gamedig": "^5.3.3",
    "http-proxy-agent": "^9.1.0",
    "https-proxy-agent": "^9.1.0",
    "mysql2": "^3.22.5",
    "rcon-srcds": "^2.1.1",
    "redis": "^6.0.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2"
  },
  "keywords": [
    "game-server",
    "api",
    "tracking",
    "websocket",
    "realtime"
  ],
  "author": "jvnipers",
  "license": "MIT"
}
